# =============================================================================
# Agentic Analyst - 環境変数（手動設定の真実の源泉）
# =============================================================================
# このファイルをコピーして .env.local を作成し、値を設定してください。
# cp .env.local.example .env.local
#
# 各サブモジュールの .env.local は scripts/sync-env.sh が自動生成します:
#   source .env.credentials && ./scripts/sync-env.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Phase 2: 初期設定（必須）
# -----------------------------------------------------------------------------
# 組織のIdCインスタンスARN（アカウントレベルではなく組織レベル）
IDC_INSTANCE_ARN=arn:aws:sso:::instance/ssoins-xxxxxxxxx

# 全ユーザーが所属するIdCグループ名（Phase 1.1で作成）
IDC_ALL_USERS_GROUP=anycompany-salesmarketing

# Identity Store ID（sync-env.sh で自動設定）
# 例: d-xxxxxxxxxx
IDENTITY_STORE_ID=

# IdCポータルURL（sync-env.sh で自動設定）
# 例: https://xxxxxxxxxx.awsapps.com/start
IDC_PORTAL_URL=

# -----------------------------------------------------------------------------
# Phase 4: IdC SAML Application作成後に設定
# -----------------------------------------------------------------------------
# IdC SAML Application メタデータURL（Cognito→IdCログイン用）
# 例: https://portal.sso.ap-northeast-1.amazonaws.com/saml/metadata/xxxxxxxxxx
IDC_SAML_METADATA_URL=

# -----------------------------------------------------------------------------
# Phase 4b: IdC OAuth CMA作成後に設定
# -----------------------------------------------------------------------------
# IdC OAuth CMA Application ARN（RedeemAccessTokenフロー用）
# 例: arn:aws:sso::<IdCアカウントID>:application/<インスタンスID>/<アプリケーションID>
IDC_APPLICATION_ARN=

# -----------------------------------------------------------------------------
# Phase 5: SMUSドメイン作成後に設定
# -----------------------------------------------------------------------------
# SMUSドメインID（コンソールで作成後に取得）
# 例: dzd-xxxxxxxxx
SMUS_DOMAIN_ID=

# -----------------------------------------------------------------------------
# オプション設定
# -----------------------------------------------------------------------------
# カスタムドメイン（Route53ホストゾーンが必要）
# DOMAIN_NAME=example.com

# Bedrockモデル ID（デフォルト: global.anthropic.claude-sonnet-4-6）
# リージョン固有の推論プロファイルを使う場合は変更（例: jp., us.）
# BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
