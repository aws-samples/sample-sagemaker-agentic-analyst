  (action == AgentCore::Action::"data-catalog___subscription_request" ||
   action == AgentCore::Action::"data-catalog___subscription_list_requests" ||
   action == AgentCore::Action::"data-catalog___subscription_approve" ||
   action == AgentCore::Action::"data-catalog___subscription_reject" ||
   action == AgentCore::Action::"data-catalog___subscription_list_filters" ||
   action == AgentCore::Action::"data-catalog___subscription_cancel" ||
   action == AgentCore::Action::"data-catalog___subscription_revoke")
};",
                ],
              ],
            },
          },
          {
            "name": "38620068_DataConsumersSubscription",
            "statement": {
              "Fn::Join": [
                "",
                [
                  "permit(
  principal is AgentCore::OAuthUser, action,
  resource == AgentCore::Gateway::"",
                  {
                    "Fn::GetAtt": [
                      "AgentJwtGateway16180A67",
                      "GatewayArn",
                    ],
                  },
                  ""
) when {
  principal.hasTag("cedar_groups") &&
  principal.getTag("cedar_groups") like "*|data-consumers|*" &&
  (action == AgentCore::Action::"data-catalog___subscription_request" ||
   action == AgentCore::Action::"data-catalog___subscription_list_requests" ||
   action == AgentCore::Action::"data-catalog___subscription_list_filters" ||
   action == AgentCore::Action::"data-catalog___subscription_cancel")
};",
                ],
              ],
            },
          },
          {
            "name": "38620068_SecurityAuditorsCloudtrail",
            "statement": {
              "Fn::Join": [
                "",
                [
                  "permit(
  principal is AgentCore::OAuthUser, action,
  resource == AgentCore::Gateway::"",
                  {
                    "Fn::GetAtt": [
                      "AgentJwtGateway16180A67",
                      "GatewayArn",
                    ],
                  },
                  ""
) when {
  principal.hasTag("cedar_groups") &&
  principal.getTag("cedar_groups") like "*|security-auditors|*" &&
  (action == AgentCore::Action::"cloudtrail-query___cloudtrail_query")
};",
                ],
              ],
            },
          },
        ],
        "policyEngineName": "agentic_analyst_jwt_authz",
      },
