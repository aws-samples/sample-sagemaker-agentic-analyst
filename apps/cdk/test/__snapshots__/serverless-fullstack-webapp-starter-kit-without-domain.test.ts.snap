            "Arn",
          ],
        },
        "policies": [
          {
            "name": "38620068_DataProducersDataAccess",
            "statement": {
              "Fn::Join": [
                "",
                [
                  "permit(
  principal is AgentCore::OAuthUser, action,
  resource == AgentCore::Gateway::"",
                  {
                    "Fn::GetAtt": [
                      "AgentJwtGateway16180A67",
                      "GatewayArn",
                    ],
                  },
                  ""
) when {
  principal.hasTag("cedar_groups") &&
  principal.getTag("cedar_groups") like "*|data-producers|*" &&
  (action == AgentCore::Action::"data-access___athena_query" ||
   action == AgentCore::Action::"data-access___s3_read" ||
   action == AgentCore::Action::"data-access___s3_list")
};",
                ],
              ],
            },
          },
          {
            "name": "38620068_DataProducersCatalog",
            "statement": {
              "Fn::Join": [
                "",
                [
                  "permit(
  principal is AgentCore::OAuthUser, action,
  resource == AgentCore::Gateway::"",
                  {
                    "Fn::GetAtt": [
                      "AgentJwtGateway16180A67",
                      "GatewayArn",
                    ],
                  },
                  ""
) when {
  principal.hasTag("cedar_groups") &&
  principal.getTag("cedar_groups") like "*|data-producers|*" &&
  (action == AgentCore::Action::"data-catalog___catalog_search" ||
   action == AgentCore::Action::"data-catalog___catalog_detail" ||
   action == AgentCore::Action::"data-catalog___catalog_list_subscriptions")
};",
                ],
              ],
            },
          },
