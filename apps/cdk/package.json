{
  "name": "@aws-samples/agentic-analyst",
  "version": "0.1.0",
  "private": true,
  "license": "MIT-0",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "lint": "oxlint --config ../../oxlintrc.json --type-check --fix .",
    "lint:ci": "oxlint --config ../../oxlintrc.json --type-check --max-warnings 0 .",
    "format": "oxfmt --write .",
    "format:ci": "oxfmt --check .",
    "check": "pnpm run lint && pnpm run format",
    "check:ci": "pnpm run lint:ci && pnpm run format:ci",
    "cdk": "cdk"
  },
  "dependencies": {
    "@aws-cdk/aws-bedrock-agentcore-alpha": "2.238.0-alpha.0",
    "@aws-cdk/mixins-preview": "2.241.0-alpha.0",
    "@aws-sdk/client-bedrock-agentcore-control": "^3.1029.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1029.0",
    "@cdklabs/deploy-time-build": "^0.1.2",
    "@types/aws-lambda": "^8.10.161",
    "aws-cdk-lib": "^2.248.0",
    "cdk-nag": "^2.37.55",
    "constructs": "^10.6.0",
    "dotenv": "^17.4.2",
    "source-map-support": "^0.5.21",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^27.5.2",
    "@types/node": "^22.19.17",
    "aws-cdk": "^2.1118.0",
    "esbuild": "^0.25.12",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
