{
  "name": "@aws-samples/agentic-analyst",
  "version": "0.1.0",
  "private": true,
  "license": "MIT-0",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "lint": "oxlint --config ../../oxlintrc.json --type-check --fix .",
    "lint:ci": "oxlint --config ../../oxlintrc.json --type-check --max-warnings 0 .",
    "format": "oxfmt --write .",
    "format:ci": "oxfmt --check .",
    "check": "pnpm run lint && pnpm run format",
    "check:ci": "pnpm run lint:ci && pnpm run format:ci",
    "cdk": "cdk"
  },
  "dependencies": {
    "@aws-cdk/aws-bedrock-agentcore-alpha": "^2.238.0-alpha.0",
    "@aws-cdk/mixins-preview": "^2.241.0-alpha.0",
    "@aws-sdk/client-bedrock-agentcore-control": "^3.1003.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.987.0",
    "@cdklabs/deploy-time-build": "^0.1.1",
    "@types/aws-lambda": "^8.10.149",
    "aws-cdk-lib": "^2.241.0",
    "cdk-nag": "^2.14.29",
    "constructs": "^10.0.0",
    "dotenv": "^17.3.1",
    "source-map-support": "^0.5.21",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^27.5.0",
    "@types/node": "^22.14.1",
    "aws-cdk": "^2.1106.1",
    "esbuild": "^0.25.4",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.7.0",
    "typescript": "^5.9.2"
  }
}
