{
  "name": "gateway-tools",
  "version": "1.0.0",
  "private": true,
  "license": "MIT-0",
  "scripts": {
    "lint": "oxlint --config ../../oxlintrc.json --type-check --fix .",
    "lint:ci": "oxlint --config ../../oxlintrc.json --type-check --max-warnings 0 .",
    "format": "oxfmt --write .",
    "format:ci": "oxfmt --check .",
    "check": "pnpm run lint && pnpm run format",
    "check:ci": "pnpm run lint:ci && pnpm run format:ci",
    "test:unit": "vitest run tests/unit"
  },
  "dependencies": {
    "@agentic-analyst/datazone-auth": "workspace:*",
    "@agentic-analyst/shared-types": "workspace:*",
    "@aws-sdk/client-sso-oidc": "^3.1000.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-athena": "^3.987.0",
    "@aws-sdk/client-cloudtrail": "^3.987.0",
    "@aws-sdk/client-datazone": "^3.995.0",
    "@aws-sdk/client-identitystore": "^3.999.0",
    "@aws-sdk/client-s3": "^3.987.0",
    "@aws-sdk/client-s3-control": "^3.987.0",
    "@types/aws-lambda": "^8.10.149",
    "@types/node": "^22.14.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
