# =============================================================================
# Credentials for E2E Tests and Remote Operations
#   Next.jsは自動で読み込まない（意図しない認証を防止）
#   使用時: source .env.credentials && ./scripts/sync-env.sh
# =============================================================================

# AWS Profile（CDKデプロイ、sync-env.sh で使用）
export AWS_PROFILE=your-profile-name
export AWS_REGION=ap-northeast-1

# IdC操作用プロファイル（IdCホームリージョンが異なる場合）
export IDC_AWS_PROFILE=your-idc-profile-name
export IDC_AWS_REGION=ap-northeast-1

