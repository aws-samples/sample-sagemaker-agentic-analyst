{
  "name": "agentic-analyst",
  "private": true,
  "license": "MIT-0",
  "scripts": {
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged && pnpm -r run test:unit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxlint --config oxlintrc.json --fix",
      "oxfmt --write"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "hono": ">=4.12.14"
    }
  }
}
