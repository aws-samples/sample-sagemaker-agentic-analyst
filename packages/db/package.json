{
  "name": "@agentic-analyst/db",
  "version": "0.0.0",
  "private": true,
  "license": "MIT-0",
  "type": "module",
  "exports": {
    "./schema": "./src/schema.ts",
    "./client": "./src/client.ts",
    "./migrate": "./src/migrate.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate && tsx src/check-dsql-compat.ts",
    "migrate": "tsx --env-file=.env src/cli.ts",
    "test:unit": "vitest run --exclude '**/*.integ.test.ts'",
    "test:watch": "vitest --exclude '**/*.integ.test.ts'",
    "format": "oxfmt --write .",
    "format:ci": "oxfmt --check .",
    "lint": "oxlint --config ../../oxlintrc.json --fix .",
    "lint:ci": "oxlint --config ../../oxlintrc.json --max-warnings 0 .",
    "check": "pnpm run lint && pnpm run format",
    "check:ci": "pnpm run lint:ci && pnpm run format:ci"
  },
  "dependencies": {
    "@aws/aurora-dsql-node-postgres-connector": "^0.1.8",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
